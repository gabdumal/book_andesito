---
import type { ImageMetadata } from "astro";

import { Image as AstroImage } from "astro:assets";

interface Props {
  alt: string;
  src: ImageMetadata;
}

const { alt, src } = Astro.props;
---

<style>
  .image-item {
    display: block;
    width: min-content;
    max-height: 100%;
    max-width: 100%;
    object-fit: cover;
  }
</style>

<AstroImage alt={alt} class="image-item" src={src} />
